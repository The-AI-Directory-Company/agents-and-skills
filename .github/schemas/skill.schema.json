{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Frontmatter",
  "description": "Schema for SKILL.md frontmatter following the Agent Skills spec",
  "type": "object",
  "required": ["name", "description", "metadata"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "maxLength": 64,
      "description": "Lowercase hyphenated slug. Must match folder name."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "What the agent does and when to use it."
    },
    "metadata": {
      "type": "object",
      "required": ["displayName", "categories"],
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for UI display."
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "engineering",
              "product-management",
              "project-management",
              "design",
              "data",
              "business",
              "communication",
              "security",
              "leadership",
              "operations"
            ]
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "At least one category from the allowed list."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9 ./_-]*$"
          },
          "uniqueItems": true,
          "description": "Freeform tags for search and discovery."
        },
        "author": {
          "type": "string",
          "description": "Convex _id of the proposer."
        },
        "refURL": {
          "type": "string",
          "description": "URL crediting the original source."
        },
        "worksWellWithAgents": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true,
          "description": "Slugs of complementary agents."
        },
        "worksWellWithSkills": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true,
          "description": "Slugs of complementary skills."
        }
      }
    }
  }
}
